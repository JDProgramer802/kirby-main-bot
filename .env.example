# Variables de Entorno — Kirby Dream Bot
# Copia este archivo a .env y rellena los valores

# ──────────────────────────────────────────
# CONFIGURACIÓN DEL BOT
# ──────────────────────────────────────────
PREFIJO=/
OWNER_NUMBER=5491100000000
BOT_NAME=Kirby Dream Bot
BOT_DEV=Dream Kirby Developer

# ──────────────────────────────────────────
# BASE DE DATOS POSTGRESQL (Supabase / URL)
# ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:tu_password@host:5432/tu_db

# ──────────────────────────────────────────
# IMGBB API (para banners dinámicos)
# ──────────────────────────────────────────
IMGBB_API_KEY=tu_api_key_de_imgbb

# ──────────────────────────────────────────
# ZONA HORARIA
# ──────────────────────────────────────────
TIMEZONE=America/Lima

# ──────────────────────────────────────────
# MODOS DEL BOT (true/false)
# ──────────────────────────────────────────
MODO_PUBLICO=true
NSFW_GLOBAL=false
